{
  "name": "@svasimahmed283/jira-mcp-oauth",
  "version": "0.1.3",
  "description": "Model Context Protocol server for Atlassian Jira: PAT or browser SSO cookies for REST, with optional Confluence attachment helpers—configure for your own Jira site (Cloud or Data Center).",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "bin": "src/index.js",
  "files": [
    "src",
    "scripts",
    "tests",
    ".env.example",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Wasim-Shaikh25/jira-mcp-auth.git"
  },
  "homepage": "https://github.com/Wasim-Shaikh25/jira-mcp-auth#readme",
  "bugs": {
    "url": "https://github.com/Wasim-Shaikh25/jira-mcp-auth/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "jira",
    "jira-cloud",
    "atlassian",
    "cursor",
    "sso"
  ],
  "scripts": {
    "start": "node src/index.js",
    "login": "node scripts/jira-login.mjs",
    "test": "node --test tests/",
    "validate": "node scripts/validate.mjs",
    "install-browser": "npx playwright install chromium"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "node-fetch": "^3.3.2",
    "playwright": "^1.43.0"
  }
}
