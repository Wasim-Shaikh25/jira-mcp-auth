# Jira connection settings belong in Cursor MCP only:
# %USERPROFILE%\.cursor\mcp.json → mcpServers.jira-sso.env
#
# Example mcp.json fragment:
#   "jira-sso": {
#     "command": "node",
#     "args": ["C:/path/to/jira-mcp-oauth/src/index.js"],
#     "env": {
#       "JIRA_BASE_URL": "https://jira.company.com",
#       "JIRA_REST_API_PREFIX": "/rest/api/2",
#       "JIRA_DESCRIPTION_FORMAT": "auto",
#       "JIRA_LOGIN_WAIT_SECONDS": "90"
#     }
#   }
#
# Do NOT put JIRA_PAT (or JIRA_API_TOKEN) in this file — only in
# %USERPROFILE%\.cursor\mcp.json → mcpServers.jira-sso.env
#
# If browser SSO (jira_login) never saves cookies: set JIRA_PAT in mcp.json and PREFER_SSO_COOKIES=0,
# or delete cookies/session-<server-key>.json under this package.
#
# Optional: max attachment upload size in bytes (default 10485760)
# JIRA_MAX_ATTACHMENT_BYTES=
#
# Data Center often uses /rest/api/2 (plain-text description; list_projects uses GET /project).
# Cloud uses /rest/api/3 (ADF description; project search API). Override if needed:
# JIRA_REST_API_PREFIX=/rest/api/2
# JIRA_DESCRIPTION_FORMAT=auto|adf|plain
